---
const { title = "TheCloseReport | Daily Markets Snapshot" } = Astro.props;
---
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- SEO Meta Tags -->
    <meta name="description" content="TheCloseReport — Daily global markets snapshot. Previous day closing prices for 13 major indices across USA, India, Asia and Europe." />
    <meta name="keywords" content="stock market, daily market report, BSE Sensex, Nifty 50, Dow Jones, global indices, market snapshot, India markets" />
    <meta name="author" content="TheCloseReport" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (Social Media) -->
    <meta property="og:title" content="TheCloseReport | Daily Global Markets Snapshot" />
    <meta property="og:description" content="Previous day closing prices for 13 major global indices. Free. Daily. Automated." />
    <meta property="og:url" content="https://theclosereport.com" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="TheCloseReport" />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#3b82f6" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="TheCloseReport" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="TheCloseReport | Daily Global Markets Snapshot" />
    <meta name="twitter:description" content="Previous day closing prices for 13 major global indices. Free. Daily. Automated." />
    <meta name="twitter:site" content="@TheCloseReport" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700;800&family=Noto+Sans+Devanagari:wght@400;600;700;800&family=Noto+Sans+Telugu:wght@400;600;700;800&family=Noto+Sans+Tamil:wght@400;600;700;800&display=block" rel="stylesheet">
    <title>{title}</title>
    <style is:global>
      :root[data-theme="dark"] {
        --bg: #020817;
        --surface: #0f172a;
        --border: #1e293b;
        --text: #f1f5f9;
        --muted: #64748b;
        --up: #10b981;
        --down: #ef4444;
        --accent: #3b82f6;
      }
      :root[data-theme="light"] {
        --bg: #f8fafc;
        --surface: #ffffff;
        --border: #e2e8f0;
        --text: #0f172a;
        --muted: #64748b;
        --up: #10b981;
        --down: #ef4444;
        --accent: #3b82f6;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Inter', system-ui, sans-serif;
        transition: background 0.3s, color 0.3s;
      }
    </style>
  </head>
  <body>
    <header style="background: var(--surface); border-bottom: 1px solid var(--border); padding: 12px 16px;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px;">
    <a href="/" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
      <span style="font-size: 18px;">📊</span>
      <span style="font-size: 16px; font-weight: 800; color: var(--text); letter-spacing: -0.5px;">
        The<span style="color: var(--accent);">Close</span>Report
      </span>
    </a>
    <div style="display: flex; align-items: center; gap: 5px;">
      <button onclick="window.setLang('en')" id="lang-en" style="background: none; border: 1px solid var(--border); border-radius: 20px; padding: 3px 8px; color: var(--text); cursor: pointer; font-size: 10px; font-weight: 600;">EN</button>
      <button onclick="window.setLang('hi')" id="lang-hi" style="background: none; border: 1px solid var(--border); border-radius: 20px; padding: 3px 8px; color: var(--text); cursor: pointer; font-size: 10px; font-weight: 600;">हि</button>
      <button onclick="window.setLang('te')" id="lang-te" style="background: none; border: 1px solid var(--border); border-radius: 20px; padding: 3px 8px; color: var(--text); cursor: pointer; font-size: 10px; font-weight: 600;">తె</button>
      <button onclick="window.setLang('ta')" id="lang-ta" style="background: none; border: 1px solid var(--border); border-radius: 20px; padding: 3px 8px; color: var(--text); cursor: pointer; font-size: 10px; font-weight: 600;">த</button>
      <button id="theme-toggle" style="background: var(--border); border: none; border-radius: 20px; padding: 4px 10px; color: var(--text); cursor: pointer; font-size: 10px; font-weight: 600;">
        🌙
      </button>
    </div>
  </div>
      </header>

    <main>
      <slot />
    </main>

    <footer style="background: var(--surface); border-top: 1px solid var(--border); padding: 40px 24px;">
  <div style="max-width: 900px; margin: 0 auto;">
    
    <!-- Logo & Tagline -->
    <div style="text-align: center; margin-bottom: 24px;">
      <div style="font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 6px;">
        📊 The<span style="color: var(--accent);">Close</span>Report
      </div>
      <div style="color: var(--muted); font-size: 12px;">
        Daily Global Markets Snapshot
      </div>
    </div>

    <!-- Navigation Links -->
    <div style="display: flex; justify-content: center; gap: 24px; margin-bottom: 24px; flex-wrap: wrap;">
      <a href="/" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">Home</a>
      <a href="/archive" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">Archive</a>
      <a href="/about" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">About</a>
      <a href="/newsletter" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">Newsletter</a>
      <a href="/privacy" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">Privacy</a>    
      <a href="/terms" style="color: var(--muted); text-decoration: none; font-size: 13px; font-weight: 600;">Terms</a>
    </div>

    <!-- Divider -->
    <div style="border-top: 1px solid var(--border); margin-bottom: 20px;"></div>

    <!-- Data Source & Copyright -->
    <div style="text-align: center;">
      <div style="color: var(--muted); font-size: 11px; margin-bottom: 6px;">
        Market data sourced from <a href="https://finance.yahoo.com" target="_blank" style="color: var(--accent); text-decoration: none;">Yahoo Finance</a>
      </div>
      <div style="color: var(--muted); font-size: 11px;">
        © 2026 TheCloseReport.com · All rights reserved
      </div>
    </div>

    </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      const html = document.documentElement;
      const saved = localStorage.getItem('theme') || 'dark';
      html.setAttribute('data-theme', saved);
      toggle.textContent = saved === 'dark' ? '☀️ Light' : '🌙 Dark';
      toggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        toggle.textContent = next === 'dark' ? '☀️ Light' : '🌙 Dark';
      });
      // Language toggle
        window.setLang = function(lang) {
        localStorage.setItem('lang', lang);
        document.documentElement.setAttribute('data-lang', lang);
        document.querySelectorAll('[id^="lang-"]').forEach(btn => {
        btn.style.background = 'none';
        btn.style.color = 'var(--text)';
        });
        document.getElementById(`lang-${lang}`).style.background = 'var(--accent)';
        document.getElementById(`lang-${lang}`).style.color = '#fff';
        window.dispatchEvent(new CustomEvent('langchange', { detail: lang }));
        }

        // Load saved language
        const savedLang = localStorage.getItem('lang') || 'en';
        setLang(savedLang);
    </script>
  </body>
</html>